# ============================================
# llm_AIO 环境变量配置示例
# 使用方式：复制本文件为 .env 后按需修改
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# ============================================

# ---------- 应用 ----------
APP_NAME=Universal Model Playground Gateway & User Management System
DEBUG=True

# ---------- 用户管理 / JWT ----------
# 生产环境务必更换为随机密钥，例如: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API JSON 里时间的展示时区（IANA）。默认 Asia/Shanghai=北京时间 +08:00；改为 UTC 则输出带 Z 的 UTC
API_RESPONSE_DATETIME_TZ=Asia/Shanghai

# ---------- 数据库 ----------
# 用户管理库（默认 SQLite，也可改为 MySQL/PostgreSQL 连接串）
DATABASE_URL=sqlite:///./user_management.db
# Convert URL 库（视频等）
CONVERT_URL_DATABASE_URL=sqlite:///./videos.db

# ---------- AI 模型 API Key ----------
# 阿里云 DashScope（文本/多模态/语音/图像等）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 豆包 Volcengine
VOLCENGINE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------- 本地模型（可选） ----------
# 本地推理地址，如 Ollama
LOCAL_MODEL_URL=http://localhost:11434/v1/chat/completions

# ---------- 文件存储 ----------
# 存储类型: local 或 oss
STORAGE_TYPE=local
# 本地存储时，大模型要访问文件则需填公网可访问地址（不能用 localhost）
SERVER_URL=http://localhost:8000

# OSS 配置（仅当 STORAGE_TYPE=oss 时需要）
# 使用 OSS 时建议安装: pip install oss2
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_REGION=oss-cn-beijing

# ---------- llmfactory 微调集成（可选） ----------
# llamafactory-cli 所在目录，留空则自动检测 llmfactory/.venv
LLMFACTORY_COMMAND_PREFIX=
# 本地模型文件根目录：其下每个子目录视为一个已下载模型，用于「查看本地模型」接口
# 例如: D:\models 或 /data/models，留空则无法通过接口列举本地模型
LLMFACTORY_MODELS_DIR=
# 训练输出根目录，默认为当前工作目录下的 train_output；微调结果实际写在 train_output/SFT/ 下
# 例如: train_output 或 /data/llm/output
LLMFACTORY_DEFAULT_OUTPUT_DIR=train_output
# 合并适配器时可选：不传 export_dir 时默认导出到 train_output/merged/{适配器名}_merged
# LLMFACTORY_DEFAULT_MODEL_PATH=   # 基础模型路径
# LLMFACTORY_DEFAULT_ADAPTER_PATH= # 适配器目录（如 GET /trained-models 的 output_dir）
# LLMFACTORY_DEFAULT_EXPORT_DIR=   # 合并后导出目录（不传则用 train_output/merged/xxx_merged）
# 模型/数据集路径建议在每次请求中显式传入，或在上面配置默认
#
# 高显存操作前检查（可选）：要求指定 GPU「当前空闲显存」不低于阈值（MiB，与 nvidia-smi 一致），否则拒绝训练/合并/推理启动（HTTP 503）。
# LLMFACTORY_MIN_FREE_VRAM_MIB=0   # 0=关闭检查（默认）
# LLMFACTORY_MIN_FREE_VRAM_MIB=4096  # 示例：至少空闲 4GiB 才允许提交
# LLMFACTORY_GPU_VRAM_GUARD_INDEX=0  # 监控的 GPU 物理索引，默认 0
# LLMFACTORY_GPU_VRAM_GUARD_STRICT=false  # true：无法执行 nvidia-smi 时也拒绝；false：查不到则跳过检查

# ---------- 代码在线（code-online，可选） ----------
# run-code 会在服务器端执行任意 Python 代码，存在安全风险。
# 建议生产环境默认禁用：false
CODE_ONLINE_ENABLE_RUN_CODE=true

# 默认解释器命令名/路径（用于 env=default 或未匹配到映射时）
CODE_ONLINE_DEFAULT_PYTHON=python3

# 映射表：key=请求里的 env 名，value=该 env 对应的 python 可执行文件路径。
# 例子：同一台服务器上跑多个虚拟环境（venv/conda）时，每个 env 对应不同 python。
# 推荐用 JSON 方式（比拼接字符串更直观）。
CODE_ONLINE_LOCAL_PYTHON_ENVS_JSON='{
  "default": "/usr/bin/python3",
  "python3.10-yolov5": "/data/venvs/yolov5/bin/python",
  "python3.10-tf": "/data/venvs/tf/bin/python"
}'

# ---------- 领域 RAG / LangGraph（Knowledge_retrive_and_search 整合，可选） ----------
# 设为 false 时跳过 LangGraph 初始化，主服务照常启动
RAG_ENABLED=true
# 与 rag_llms.MODEL_CONFIGS 键一致: qwen | openai | oneapi | ollama
RAG_LLM_TYPE=qwen
# Chroma 持久化目录与集合名（需先有向量数据，可用 POST /api/v1/knowledge-retrieval/ingest-pdf 入库）
RAG_CHROMADB_DIRECTORY=chroma_db_rag
RAG_CHROMADB_COLLECTION=demo001
# LangGraph 检查点 + 跨会话记忆（SQLite）
RAG_LANGGRAPH_SQLITE=sqlite:///./data/langgraph_rag.db
# 是否注册联网搜索工具（需 ddgs 或 duckduckgo-search）
RAG_ENABLE_WEB_SEARCH=true
# 可选：导出状态图 PNG（需 graphviz/mermaid 等，失败仅打日志）
# RAG_SAVE_GRAPH_VIZ=true
# RAG_GRAPH_VIZ_PATH=data/rag_graph.png
# 检索工具在 Agent 中的描述（可按业务改写）
# RAG_RETRIEVER_DESCRIPTION=领域知识库检索工具...